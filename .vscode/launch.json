{
  "version": "0.2.0",
  "configurations": [
    {
      "name": "Next.js: debug server (port 3002)",
      "type": "node",
      "request": "launch",
      "runtimeExecutable": "npm",
      "runtimeArgs": ["run", "dev"],
      "cwd": "${workspaceFolder}",
      "serverReadyAction": {
        "action": "openExternally",
        "pattern": "Local:\\s*(https?://[^\\s]+)",
        "uriFormat": "%s"
      }
    }
  ]
}
